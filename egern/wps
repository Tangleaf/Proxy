```yaml
name: WPS 签到
description: WPS 每日签到脚本，进入活动页获取 Cookie 后每天定时签到。
author: tangboys5
homepage: https://github.com/tangboys5
icon: doc.text.fill

scriptings:
  - http_response:
      name: WPS Cookie
      match: ^https:\/\/personal-act\.wps\.cn\/activity-rubik\/activity\/page_info
      script_url: https://raw.githubusercontent.com/MaYIHEI/paperclip/refs/heads/main/app/wps/wps.cookie.js
      body_required: false
      binary_body: false
      timeout: 30
      update_interval: 86400

  - schedule:
      name: WPS 签到
      cron: "0 10 * * *"
      script_url: https://raw.githubusercontent.com/MaYIHEI/paperclip/refs/heads/main/app/wps/wps.js
      timeout: 120
      update_interval: 86400

mitm:
  hostnames:
    includes:
      - personal-act.wps.cn
```
